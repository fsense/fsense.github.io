<nav class="site-nav" aria-label="Main">
  <ul>
    {% for item in site.nav %}
      {% set isCurrent = (item.url == page.url) or (item.url != "/" and page.url.startsWith(item.url)) %}
      <li>
        <a href="{{ item.url }}"{% if isCurrent %} aria-current="page"{% endif %}>{{ item.text }}</a>
      </li>
    {% endfor %}
  </ul>
</nav>
